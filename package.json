{
  "name": "@waywake/n8n-nodes-wdt-api",
  "version": "0.2.1",
  "description": "WangDian API for n8n",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "xAmast",
    "email": "x@amast.fun"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waywake/n8n-nodes-wdt-api"
  },
  "engines": {
    "node": ">=20.15"
  },
  "packageManager": "bun@1.3.14",
  "main": "index.js",
  "scripts": {
    "generate:endpoints": "bun scripts/generate-endpoints.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc",
    "build:icons": "bun scripts/copy-icons.mjs",
    "build": "bun run generate:endpoints && bun run clean && bun run typecheck && bun run build:icons",
    "dev": "bun run typecheck --watch",
    "format": "prettier nodes credentials --write",
    "format:check": "prettier nodes credentials --check",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "lint:prepublish": "eslint -c .eslintrc.prepublish.js nodes credentials package.json",
    "prepublishOnly": "bun run build && bun run lint:prepublish"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WangDianApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WangDianApi/WangDianApi.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "n8n-workflow": "^1.82.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@waywake/wdt-sdk": "^0.1.4"
  }
}
